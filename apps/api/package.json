{
  "name": "@code-atlas/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --watch --env-file=.env -r ts-node/register/transpile-only -r tsconfig-paths/register src/main.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node --test --require ts-node/register --require tsconfig-paths/register $(find src -name '*.test.ts' -print)",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config src/lib/auth.ts --output prisma/auth.generated.prisma",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@code-atlas/shared": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@prisma/client": "^6.6.0",
    "@thallesp/nestjs-better-auth": "^2.5.1",
    "better-auth": "^1.5.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^5.6.0",
    "octokit": "^5.0.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.4",
    "@nestjs/testing": "^11.1.6",
    "@types/node": "^20.17.30",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "prisma": "^6.6.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
